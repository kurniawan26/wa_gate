# Generate dengan: mix phx.gen.secret
SECRET_KEY_BASE=

# Kunci enkripsi pesan (WAJIB, jangan masukkan ke version control)
# Generate dengan: openssl rand -base64 32
ENCRYPTION_KEY=

# Domain publik aplikasi (tanpa http:// dan tanpa port)
PHX_HOST=yourdomain.com
# Scheme: http atau https
PHX_SCHEME=https

# Koneksi database (format: ecto://USER:PASS@HOST/DATABASE)
DATABASE_URL=ecto://user:password@host:5432/wa_gate_db

# Waha WhatsApp API
WAHA_API_KEY=changeme

# URL publik aplikasi ini untuk menerima webhook dari Waha
# Contoh: https://yourdomain.com/api/webhooks/whatsapp
WEBHOOK_URL=https://yourdomain.com/api/webhooks/whatsapp

# API key untuk endpoint POST /api/messages
APP_API_KEY=

# Jumlah koneksi database (opsional, default 10)
POOL_SIZE=10

# Versi image Docker (opsional, default: latest)
APP_VERSION=latest
