# Generate dengan: mix phx.gen.secret
SECRET_KEY_BASE=

# Kunci enkripsi pesan (WAJIB, jangan taruh di DB/version control)
# Generate dengan: openssl rand -base64 32
ENCRYPTION_KEY=

# Domain/IP publik aplikasi (tanpa http://)
PHX_HOST=localhost

# Koneksi database (wajib di prod, format: ecto://USER:PASS@HOST/DATABASE)
DATABASE_URL=

# API key Evolution API
EVOLUTION_API_KEY=lt67scX4Hbodj0kpaQYW8MPPIEoh94qpcvkU5COaiec=

# API key untuk endpoint POST /api/messages
APP_API_KEY=

# Jumlah koneksi database (opsional, default 10)
POOL_SIZE=10
